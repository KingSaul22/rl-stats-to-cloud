{
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": [
    "--all-features",
    "--",
    "-D",
    "warnings"
  ],
  "rust-analyzer.cargo.allTargets": true,
  // Forward the same arguments you used before
  // "rust-analyzer.cargo.extraArgs": [
  //   "--all-features"
  // ],
  // (Optional) make the language server always enable diagnostics
  "rust-analyzer.diagnostics.enable": true,
  "chat.tools.terminal.autoApprove": {
    "/^bun run build 2>&1$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo check -p rl_stats_core$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo clippy --all-targets --all-features -- -D warnings -D clippy::all -D clippy::pedantic -D clippy::nursery$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo check -p rl-stats-to-cloud$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo clippy -p rl-stats-to-cloud --all-targets --all-features -- -D warnings -D clippy::all -D clippy::pedantic -D clippy::nursery$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^cargo clippy -p rl-stats-to-cloud --all-targets --all-features -- -D warnings -D clippy::all -D clippy::pedantic -D clippy::nurserys$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
