{
  "compilerOptions": {
    "types": ["node", "@tauri-apps/api"],

    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* Strict Type Checking */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "useUnknownInCatchVariables": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    // 1. Prevents bugs when moving code between Windows (case-insensitive) 
    // and Linux (case-sensitive) file systems.
    "forceConsistentCasingInFileNames": true,

    // 2. Complements "noUncheckedIndexedAccess". It forces you to use 
    // obj['key'] instead of obj.key for types with index signatures.
    "noPropertyAccessFromIndexSignature": true,

    // 3. Ensures that your TypeScript code doesn't rely on features 
    // that the Tauri WebView (Chrome/WebKit) might not support.
    "verbatimModuleSyntax": true
  },
  "include": ["src"]
}
