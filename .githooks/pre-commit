#!/bin/bash
set -e

echo "=== Pre-commit checks starting ==="

# Forzar a que Git Bash en Windows reconozca las rutas del sistema
export PATH="$PATH:/c/Program Files/nodejs:/c/Users/$USER/.cargo/bin:/c/Users/$USER/.bun/bin"

# 1. Validar TypeScript (Frontend)
echo "Running Frontend TypeScript validation..."
if command -v bun >/dev/null 2>&1; then
    bun run tsc
elif command -v npm >/dev/null 2>&1; then
    npm run tsc
else
    echo "warning: 'bun' or 'npm' not found in GUI environment. Skipping tsc check."
fi

# 2. Validar formato en Rust (Backend)
echo "Running Backend Formatting check..."
if command -v cargo >/dev/null 2>&1; then
    cargo fmt --all -- --check
else
    echo "error: 'cargo' is required but not found in GitHub Desktop PATH." >&2
    exit 1
fi

# 3. Ejecutar Clippy (Linter estricto de Rust)
echo "Running Backend Clippy lints..."
if command -v cargo >/dev/null 2>&1; then
    cargo clippy --all-targets --all-features -- -D warnings -D clippy::all -D clippy::pedantic -D clippy::nursery
fi

echo "=== Pre-commit checks passed cleanly ==="